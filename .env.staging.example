# Vaultic Staging Environment Variables
# Copy to .env on VPS at /var/www/vaultic/.env
# These values are set via GitLab CI/CD Variables during deploy

# PostgreSQL
POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM

# Server
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING
RUST_LOG=info

# Extension build
VITE_API_URL=https://vaultic.inetdev.io.vn
