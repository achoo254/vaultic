# Vaultic Staging Environment
# Copy to .env.staging and fill in real values
# NEVER commit .env.staging — it contains secrets

# PostgreSQL
POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM

# Server
DATABASE_URL=postgres://vaultic:CHANGE_ME_STRONG_RANDOM@postgres:5432/vaultic
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING
RUST_LOG=info
SERVER_PORT=8080

# Extension
VITE_API_URL=https://vaultic.inetdev.io.vn
