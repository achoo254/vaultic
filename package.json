{
  "name": "vaultic",
  "private": true,
  "version": "0.1.0",
  "description": "Open-source, extension-first password manager with zero-knowledge encryption",
  "license": "AGPL-3.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:dattqh": "turbo dev:dattqh",
    "dev:ext:dattqh": "pnpm --filter @vaultic/extension dev:dattqh",
    "dev:be:dattqh": "pnpm --filter @vaultic/backend dev:dattqh",
    "build:ext:staging": "pnpm --filter @vaultic/extension build:staging",
    "build:ext:production": "pnpm --filter @vaultic/extension build:production",
    "build:be:staging": "turbo build:staging",
    "build:be:production": "pnpm --filter @vaultic/backend build",
    "lint": "turbo lint",
    "test": "turbo test"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.1",
    "turbo": "^2",
    "typescript": "^5.7",
    "vitest": "^4.1.1"
  },
  "packageManager": "pnpm@9.15.0"
}
