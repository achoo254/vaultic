interface VaultItemPlaintext {
  name: string;
  url?: string;
  username?: string;
  password?: string;
  notes?: string;
  tags?: string[];
}

interface VaultItemEncrypted {
  id: string;
  folder_id?: string;
  item_type: ItemType;
  encrypted_data: string;  // base64(nonce + ciphertext)
