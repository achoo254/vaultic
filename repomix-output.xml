<file path="turbo.json">
{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "persistent": true,
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".output/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["build"]
    }
  }
}
</file>

<file path=".gitlab-ci.yml">
stages:
  - test
  - build
  - deploy

variables:
  CARGO_HOME: /cache/cargo

# --- Rust ---

rust-test:
  stage: test
  image: rust:1.82-bookworm
  script:
    - cargo test --workspace
    - cargo clippy --all-targets -- -D warnings
    - cargo fmt --check
  cache:
    key: rust-deps
    paths:
      - target/

# --- Node.js ---

node-build:
  stage: test
  image: node:22-alpine
  before_script:
    - corepack enable
    - pnpm install --frozen-lockfile
  script:
    - pnpm build
    - pnpm lint
  cache:
    key: node-deps
    paths:
      - node_modules/
      - packages/*/node_modules/

# --- Extension Build ---

extension-build:
  stage: build
  image: node:22-alpine
  only:
    - main
  before_script:
    - corepack enable
    - pnpm install --frozen-lockfile
  script:
    - pnpm --filter @vaultic/extension build
    - cd packages/extension/.output/chrome-mv3 && zip -r ../../../../vaultic-extension.zip .
  artifacts:
    paths:
      - vaultic-extension.zip
    expire_in: 30 days
  cache:
    key: node-deps
    paths:
      - node_modules/
      - packages/*/node_modules/

# --- Deploy Staging ---

deploy-staging:
  stage: deploy
  image: alpine:3.20
  only:
    - main
  before_script:
    - apk add --no-cache openssh-client
    - mkdir -p ~/.ssh
    - cp "$DEPLOY_SSH_KEY" ~/.ssh/id_ed25519
    - chmod 600 ~/.ssh/id_ed25519
    - ssh-keyscan -p "$DEPLOY_PORT" "$DEPLOY_HOST" >> ~/.ssh/known_hosts 2>/dev/null
  script:
    - |
      SSH_CMD="ssh -p $DEPLOY_PORT -o StrictHostKeyChecking=no $DEPLOY_USER@$DEPLOY_HOST"

      # Ensure deploy directory exists
      $SSH_CMD "mkdir -p $DEPLOY_PATH/extension"

      # Install Docker if not present
      $SSH_CMD "command -v docker || (dnf install -y dnf-plugins-core && dnf config-manager --add-repo https://download.docker.com/linux/centos/docker-ce.repo && dnf install -y docker-ce docker-ce-cli containerd.io docker-compose-plugin && systemctl enable --now docker)"

      # Setup deploy key for git access if not done
      $SSH_CMD "test -d $DEPLOY_PATH/.git || (cd $DEPLOY_PATH && git clone git@gitlabs.inet.vn:dattqh/vaultic.git .)"

      # Pull latest code
      $SSH_CMD "cd $DEPLOY_PATH && git fetch origin main && git reset --hard origin/main"

      # Write .env.staging from CI variables
      $SSH_CMD "cat > $DEPLOY_PATH/.env.staging << ENVEOF
      POSTGRES_PASSWORD=$POSTGRES_PASSWORD
      DATABASE_URL=postgres://vaultic:$POSTGRES_PASSWORD@postgres:5432/vaultic
      JWT_SECRET=$JWT_SECRET
