    .error-text { font-size: 14px; color: #71717a; margin-bottom: 24px; }
    .footer { margin-top: 32px; font-size: 12px; color: #a1a1aa; }
    .footer a { color: #2563eb; text-decoration: none; }
    #loading { color: #71717a; font-size: 14px; }
    .hidden { display: none !important; }
  </style>
</head>
<body>
  <div class="container">
    <!-- Loading state -->
    <div id="view-loading">
      <div class="logo">Vaultic</div>
      <div id="loading">Loading...</div>
    </div>

    <!-- View Prompt (before clicking "View") -->
    <div id="view-prompt" class="hidden">
      <div class="logo">🛡️ Vaultic</div>
      <div class="subtitle">Someone shared a secret with you</div>
      <div class="warning" id="warning-text">This link can only be viewed 1 time</div>
      <button class="btn" id="btn-view">View Credential</button>
      <div class="footer">Powered by <a href="https://vaultic.app">Vaultic</a></div>
    </div>

    <!-- Revealed content -->
    <div id="view-revealed" class="hidden">
      <div class="logo">🛡️ Vaultic</div>
      <div class="subtitle">Shared secret</div>
      <div id="content-structured" class="hidden"></div>
      <div id="content-raw" class="hidden"></div>
      <button class="btn btn-copy" id="btn-copy-all">📋 Copy to Clipboard</button>
      <div class="disappear-warning">⚠ This will disappear when you close this page</div>
      <div class="footer">Powered by <a href="https://vaultic.app">Vaultic</a></div>
    </div>

    <!-- Error / Expired -->
    <div id="view-error" class="hidden">
      <div class="error-icon">🚫</div>
      <div class="error-title" id="error-title">Link Expired</div>
      <div class="error-text" id="error-text">This share link is no longer available.</div>
      <div class="footer">Powered by <a href="https://vaultic.app">Vaultic</a></div>
    </div>
  </div>

  <script>
    const NONCE_SIZE = 12;
    const shareId = window.location.pathname.split('/').pop();
    const keyFragment = window.location.hash.slice(1);

    async function init() {
      if (!shareId || !keyFragment) {
        showError('Invalid Link', 'This share link is malformed.');
        return;
      }

      try {
        // Fetch metadata first — does NOT count a view
        const metaRes = await fetch(`/api/share/${shareId}/meta`);
        if (!metaRes.ok) {
          const err = await metaRes.json().catch(() => ({}));
          if (metaRes.status === 410) {
            showError('Link Expired', err.error || 'This link has expired or reached max views.');
          } else if (metaRes.status === 404) {
            showError('Not Found', 'This share link does not exist.');
          } else {
            showError('Error', err.error || 'Failed to load share.');
          }
          return;
        }

        const meta = await metaRes.json();
        showPrompt(meta);
      } catch {
        showError('Network Error', 'Could not connect to server.');
      }
    }

    function showPrompt(meta) {
      document.getElementById('view-loading').classList.add('hidden');
      document.getElementById('view-prompt').classList.remove('hidden');

      // Dynamic warning based on actual share config
      const warningEl = document.getElementById('warning-text');
      if (meta.max_views === null || meta.max_views === undefined) {
        warningEl.textContent = 'This link has no view limit';
      } else {
        const remaining = meta.max_views - meta.current_views;
        if (remaining <= 1) {
          warningEl.textContent = 'This link can only be viewed 1 more time';
        } else {
          warningEl.textContent = `This link can be viewed ${remaining} more times`;
        }
      }

      document.getElementById('btn-view').addEventListener('click', async () => {
        try {
          // Fetch content — THIS counts the view
          const res = await fetch(`/api/share/${shareId}`);
          if (!res.ok) {
            const err = await res.json().catch(() => ({}));
            showError('Error', err.error || 'Failed to load share.');
            return;
          }
          const data = await res.json();
          const plaintext = await decryptShare(data.encrypted_data, keyFragment);
          showRevealed(plaintext);
        } catch {
          showError('Decryption Failed', 'Could not decrypt this share. The link may be corrupted.');
        }
      });
    }

    function showRevealed(plaintext) {
      document.getElementById('view-prompt').classList.add('hidden');
      document.getElementById('view-revealed').classList.remove('hidden');

      let copyText = plaintext;

      // Try to parse as JSON (structured credential from vault)
      try {
        const parsed = JSON.parse(plaintext);
        if (parsed.username || parsed.password || parsed.name) {
          const container = document.getElementById('content-structured');
          container.classList.remove('hidden');
          let html = '';
          if (parsed.name) html += field('Name', parsed.name);
          if (parsed.username) html += field('Username', parsed.username);
          if (parsed.password) html += field('Password', parsed.password);
          container.innerHTML = html;
          copyText = Object.entries(parsed).map(([k, v]) => `${k}: ${v}`).join('\n');

          // Wire copy buttons
          container.querySelectorAll('.field-copy').forEach(btn => {
            btn.addEventListener('click', () => {
              navigator.clipboard.writeText(btn.dataset.value);
              btn.textContent = '✓';
              setTimeout(() => btn.textContent = '📋', 1500);
            });
          });
          return;
        }
      } catch { /* Not JSON — raw text */ }

      // Raw text display
      const raw = document.getElementById('content-raw');
      raw.classList.remove('hidden');
      raw.innerHTML = `<div class="raw-text">${escapeHtml(plaintext)}</div>`;

      document.getElementById('btn-copy-all').addEventListener('click', () => {
        navigator.clipboard.writeText(copyText);
        document.getElementById('btn-copy-all').textContent = '✓ Copied!';
        setTimeout(() => document.getElementById('btn-copy-all').textContent = '📋 Copy to Clipboard', 2000);
      });
    }

    function showError(title, text) {
      document.getElementById('view-loading').classList.add('hidden');
      document.getElementById('view-prompt').classList.add('hidden');
      document.getElementById('view-error').classList.remove('hidden');
      document.getElementById('error-title').textContent = title;
      document.getElementById('error-text').textContent = text;
    }

    function field(label, value) {
      return `<div class="field"><div class="field-label">${label}</div><div class="field-value"><span>${escapeHtml(value)}</span><button class="field-copy" data-value="${escapeAttr(value)}">📋</button></div></div>`;
    }

    function escapeHtml(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
    function escapeAttr(s) { return s.replace(/&/g,'&amp;').replace(/"/g,'&quot;'); }

    async function decryptShare(encryptedBase64, keyBase64) {
      const rawKey = Uint8Array.from(atob(keyBase64), c => c.charCodeAt(0));
      const key = await crypto.subtle.importKey('raw', rawKey, { name: 'AES-GCM' }, false, ['decrypt']);
      const data = Uint8Array.from(atob(encryptedBase64), c => c.charCodeAt(0));
      const nonce = data.slice(0, NONCE_SIZE);
      const ciphertext = data.slice(NONCE_SIZE);
      const plaintext = await crypto.subtle.decrypt({ name: 'AES-GCM', iv: nonce }, key, ciphertext);
      return new TextDecoder().decode(plaintext);
    }

    init();
  </script>
</body>
</html>
</file>

