# Vaultic Backend — DattQH local dev
NODE_ENV=development
SERVER_PORT=8182

# MongoDB
MONGODB_URI=mongodb://localhost:27017/vaultic_db

# Auth
JWT_SECRET=change-me-in-production
AUTH_HASH_KEY=change-me-to-random-256-bit-hex

# Token TTL
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=7

# CORS
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
