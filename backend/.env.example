# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/vaultic

# JWT signing secret — keep secret, min 32 random bytes
JWT_SECRET=change-me-to-random-256-bit-hex

# Auth hash HMAC key — MUST differ from JWT_SECRET, min 32 random bytes
AUTH_HASH_KEY=change-me-to-random-256-bit-hex

# Server port (default: 8080)
SERVER_PORT=8080

# Access token TTL in minutes (default: 15)
ACCESS_TOKEN_TTL_MIN=15

# Refresh token TTL in days (default: 7)
REFRESH_TOKEN_TTL_DAYS=7

# CORS allowed origins (comma-separated, leave unset to block all cross-origin)
# CORS_ORIGIN=chrome-extension://your-extension-id
