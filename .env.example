# ── Vaultic Environment Variables — Master Reference ──
# This file is NOT used by any tool directly.
# Each package has its own .env files. See:
#   backend/.env.example        — backend vars
#   client/apps/extension/.env.example — extension vars
#
# To create a personal env:
#   cp backend/.env.example backend/.env.dattqh
#   cp client/apps/extension/.env.example client/apps/extension/.env.dattqh
#   Then run: pnpm dev:dattqh

# ── Backend vars ──
MONGODB_URI=mongodb://localhost:27017/vaultic_db
NODE_ENV=development
SERVER_PORT=8080
JWT_SECRET=change-me-in-production
AUTH_HASH_KEY=change-me-to-random-256-bit-hex
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=7
CORS_ORIGIN=*
LOG_LEVEL=info

# ── Extension vars (VITE_ prefix required) ──
VITE_API_URL=http://localhost:8080
VITE_SHARE_URL=http://localhost:8080/s
